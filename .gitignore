.gm/
node_modules/
capture/stream.ndjson
capture/diag.ndjson
*.log
*.png
.gm/browser-profile/
.gm/browser-profile-*/
--session-id
--wait
.claude/*
!.claude/workflows/
.claude/workflows/*
!.claude/workflows/*.js
