# node toolchain + playwright artifacts
# playwriter drops a transient .gitignore (containing .gm/pw-sock-*/) into whatever cwd it runs in;
# when a browser-verb script runs with cwd in src/shaders it lands here. Ignore the stray.
src/shaders/.gitignore
/node_modules/
/test-results/
/playwright-report/
tests/**/*-snapshots/
.kilo/

