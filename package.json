{
  "name": "mapspinner",
  "version": "0.1.236",
  "description": "WebGL2 Earth-scale terrain rendering SDK for interactive globe applications",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./height-cpu": "./src/height-cpu.js",
    "./anchor-field": "./src/anchor-field.js",
    "./glsl-rt": "./src/glsl-rt.js",
    "./height-gen": "./src/height-gen.js",
    "./planet-orchestrator": "./src/planet-orchestrator.js",
    "./quadtree": "./src/quadtree.js",
    "./*": "./src/*"
  },
  "type": "module",
  "scripts": {
    "gen": "node scripts/gen-height.mjs",
    "test": "node scripts/gen-height.mjs && node --test \"src/**/*.test.js\"",
    "dev": "PORT=8080 node server.js",
    "lab": "node scripts/lab.mjs",
    "lab:heightmap": "node scripts/lab.mjs heightmap",
    "lab:build": "node scripts/lab.mjs build",
    "lab:parity": "node scripts/lab.mjs parity",
    "ab": "node scripts/ab-elevation.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AnEntrypoint/mapspinner.git"
  },
  "keywords": [
    "WebGL2",
    "terrain",
    "rendering",
    "SDK",
    "globe",
    "3D"
  ],
  "author": "",
  "license": "MIT"
}
